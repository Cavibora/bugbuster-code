package main

import (
	"context"
	"fmt"
	"io"
	"os"
	"strings"
	"time"

	"bugbuster-code/pkg/agent"
	"bugbuster-code/pkg/config"
	"bugbuster-code/pkg/i18n"
	"bugbuster-code/pkg/provider"
	"bugbuster-code/pkg/theme"
	"bugbuster-code/pkg/tools"

	"github.com/fatih/color"
	"github.com/spf13/cobra"
)

var (
	execTimeout int    // --timeout, seconds (0 = no limit)
	execJSON    bool   // --json — JSONL events to stderr
	execOutput  string // -o — write last response to file
)

// execCmd creates subcommand exec
func execCmd() *cobra.Command {
	cmd := &cobra.Command{
		Use:   "exec [prompt]",
		Short: i18n.T("cli_subcommands.exec_short"),
		Long:  i18n.T("cli_subcommands.exec_long"),
		Args:  cobra.MaximumNArgs(1),
		Run:   runExec,
	}
	cmd.Flags().IntVar(&execTimeout, "timeout", 0, i18n.T("cli_flag.exec_timeout"))
	cmd.Flags().BoolVar(&execJSON, "json", false, i18n.T("cli_flag.exec_json"))
	cmd.Flags().StringVarP(&execOutput, "output", "o", "", i18n.T("cli_flag.exec_output"))
	return cmd
}

// runExec — non-interactive mode
func runExec(cmd *cobra.Command, args []string) {
	cfg := loadConfig()

	// Initialize i18n
	lang := langFlag
	if lang == "" {
		lang = cfg.Agent.Language
	}
	if lang == "" {
		lang = "en"
	}
	i18n.Init(lang)

	// Initialize theme
	appTheme = theme.ResolveTheme(cfg.Theme)

	// Resolve prompt (argument + stdin pipe)
	prompt := resolveExecPrompt(args)
	if prompt == "" {
		color.Red("%s", i18n.T("cli_error.exec_no_prompt"))
		os.Exit(1)
	}

	// Create provider
	p, err := createProvider(cfg)
	if err != nil {
		color.Red("%s", i18n.T("cli_error.provider_create", err))
		os.Exit(1)
	}

	// Create agent (without change tracker — exec does not need undo)
	loop := createAgentLoop(cfg, p, nil, "")
	loop.SetNonInteractive(true)

	// In non-interactive mode ask_user is skipped
	if askUser, ok := loop.Tools["ask_user"].(*tools.AskUserTool); ok {
		askUser.NonInteractive = true
	}

	// Context with timeout
	ctx := context.Background()
	if execTimeout > 0 {
		var cancel context.CancelFunc
		ctx, cancel = context.WithTimeout(ctx, time.Duration(execTimeout)*time.Second)
		defer cancel()
	}

	// Handle Ctrl+C
	sigCh := make(chan os.Signal, 1)
	go func() {
		<-sigCh
		os.Exit(3) // interrupted
	}()

	// Start streaming
	exitCode := runExecStream(ctx, loop, cfg, p.Name(), prompt)
	os.Exit(exitCode)
}

// resolveExecPrompt resolves prompt from arguments and stdin
func resolveExecPrompt(args []string) string {
	// Read stdin if piped
	var stdinData string
	if !isTerminal() {
		data, err := io.ReadAll(os.Stdin)
		if err == nil && len(data) > 0 {
			stdinData = strings.TrimSpace(string(data))
		}
	}

	if len(args) > 0 {
		argPrompt := args[0]
		if argPrompt == "-" {
			// prompt from stdin
			return stdinData
		}
		// Argument = prompt, stdin = additional context
		if stdinData != "" {
			return argPrompt + "\n\n---\nstdin input:\n" + stdinData
		}
		return argPrompt
	}

	// No argument — prompt from stdin
	return stdinData
}

// runExecStream starts streaming and handles events
func runExecStream(ctx context.Context, loop *agent.AgentLoop, cfg *config.BugBusterConfig, providerName string, prompt string) int {
	eventCh, err := loop.StreamWithCancel(ctx, prompt)
	if err != nil {
		fmt.Fprintf(os.Stderr, "%s\n", i18n.T("cli_error.general", err))
		return 1
	}

	var lastText strings.Builder
	var toolCalls int
	var errorSeen bool
	var genStart, genEnd time.Time
	var totalGenDur time.Duration

	for event := range eventCh {
		switch event.Type {
		case provider.EventTextDelta:
			if event.Text != "" {
				lastText.WriteString(event.Text)
				if !execJSON {
					fmt.Print(event.Text)
				}
				// Track generation time for accurate speed calculation
				if genStart.IsZero() {
					genStart = time.Now()
				} else if !genEnd.IsZero() {
					totalGenDur += time.Since(genEnd)
				}
				genEnd = time.Now()
			}
		case provider.EventThinking:
			if execJSON {
				emitJSONL(map[string]any{
					"type": "thinking",
					"text": event.Text,
				})
			}
		case provider.EventToolCallStart:
			// Accumulate generation time for tool call tokens before resetting
			if !genEnd.IsZero() {
				totalGenDur += time.Since(genEnd)
			}
			genEnd = time.Time{}
			toolCalls++
			if execJSON {
				emitJSONL(map[string]any{
					"type":    "tool_call_start",
					"tool":    event.ToolName,
					"call_id": event.ToolCallID,
				})
			} else {
				fmt.Fprintf(os.Stderr, "  ⏺ %s\n", event.ToolName)
			}
		case provider.EventToolCallEnd:
			// Reset genEnd so tool execution time is not counted as generation time
			genEnd = time.Time{}
			if execJSON {
				emitJSONL(map[string]any{
					"type":     "tool_call_end",
					"tool":     event.ToolName,
					"call_id":  event.ToolCallID,
					"ok":       event.ToolOK,
					"duration": event.Duration.String(),
				})
			} else {
				status := "✓"
				if !event.ToolOK {
					status = "✗"
				}
				fmt.Fprintf(os.Stderr, "  ⎿ %s %s\n", status, event.ToolName)
			}
		case provider.EventDone:
			if execJSON {
				emitJSONL(map[string]any{
					"type":       "done",
					"tool_calls":  toolCalls,
					"duration":    event.Duration.String(),
					"input_tokens":  event.InputTokens,
					"output_tokens": event.OutputTokens,
				})
			} else {
				// Status line to stderr
				fmt.Fprintf(os.Stderr, "%s\n", FormatStatusLineEx(
					event.InputTokens, event.OutputTokens,
					event.Duration, totalGenDur, 0, 0, providerName, "",
				))
			}

			// Write to file if -o
			if execOutput != "" {
				text := strings.TrimSpace(lastText.String())
				if err := os.WriteFile(execOutput, []byte(text), 0644); err != nil {
					fmt.Fprintf(os.Stderr, "error writing output: %v\n", err)
					return 1
				}
			}

			if errorSeen {
				return 1
			}
			return 0

		case provider.EventError:
			errorSeen = true
			if execJSON {
				emitJSONL(map[string]any{
					"type":    "error",
					"message": event.Error.Error(),
				})
			} else {
				fmt.Fprintf(os.Stderr, "error: %v\n", event.Error)
			}

		case provider.EventUsage:
			// Tokens — use in final status line
		}
	}

	// If we got here — check context
	if ctx.Err() == context.DeadlineExceeded {
		if execJSON {
			emitJSONL(map[string]any{
				"type":    "error",
				"message": "timeout",
				"code":    2,
			})
		} else {
			fmt.Fprintf(os.Stderr, "%s\n", i18n.T("cli_error.exec_timeout"))
		}
		return 2
	}

	if errorSeen {
		return 1
	}
	return 0
}

// emitJSONL writes JSONL event to stderr
func emitJSONL(event map[string]any) {
	// Simple JSON — no external dependencies
	var parts []string
	for k, v := range event {
		var val string
		switch tv := v.(type) {
		case string:
			val = fmt.Sprintf("%q", tv)
		case bool:
			val = fmt.Sprintf("%t", tv)
		case int:
			val = fmt.Sprintf("%d", tv)
		default:
			val = fmt.Sprintf("%q", fmt.Sprintf("%v", tv))
		}
		parts = append(parts, fmt.Sprintf("%q:%s", k, val))
	}
	fmt.Fprintf(os.Stderr, "{%s}\n", strings.Join(parts, ","))
}